# -----------------------------------------------------------------------------
# Supabase (chatbot / leads / analytics) — GWA-163
# Copy to `.env.local` and fill in secrets. Never commit `.env.local`.
#
# Service role key must only exist server-side (e.g. in deployment secrets).
# -----------------------------------------------------------------------------

# Project URL (safe to expose to the browser if you also use anon key client-side later)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Server-only — bypasses RLS; do not prefix with NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=

# Official site contact for chatbot-related server flows (must be @growwiseschool.org)
GROWWISE_CONTACT_EMAIL=contact@growwiseschool.org

# Optional: set to 1 in CI so `npm run build` fails if the three variables above are missing/invalid
# REQUIRE_CHATBOT_SUPABASE_AT_BUILD=1
