# Environment Variables Example
# Copy this file to .env.local and add your actual values

# API Configuration
NEXT_PUBLIC_USE_MOCK=true
NEXT_PUBLIC_API_BASE=https://api.yourserver.com
OPENAI_API_KEY=sk-your_openai_api_key_here

# Google Analytics 4 Configuration
# Get your GA4 Measurement ID from Google Analytics > Admin > Data Streams
# Format: G-XXXXXXXXXX (e.g., G-HP143C77W2)
NEXT_PUBLIC_GA_ID=G-HP143C77W2
# Optional: Google Tag Manager (if you prefer GTM). Format: GTM-YYYYYYY
# (Keep the value alone on this line — a trailing # comment on the same line can corrupt the ID.)
NEXT_PUBLIC_GTM_ID=GTM-TNFBBQJM
# If you use GTM, the app will push `virtual_page_view` events to dataLayer on client route changes.
# Recommended GTM setup:
# 1) In GTM, create a GA4 Event tag (Tag Type: GA4 Event) and set Event Name = "virtual_page_view".
# 2) Use the Built-in Variables for {{Page Path}} and {{Page Title}} or map incoming dataLayer variables.
# 3) Trigger: Custom Event -> Event name equals "virtual_page_view".
# Alternatively: disable automatic page_view in the GA4 Configuration tag and listen for these events instead.
# Public / canonical site URL (no trailing slash): SEO, sitemap, JSON-LD, Stripe success URLs. Use NEXT_PUBLIC_SITE_URL only — NEXT_PUBLIC_BASE_URL is not read by the app.
NEXT_PUBLIC_SITE_URL=https://growwiseschool.org

# Backend URL (Express API). Required on Vercel Preview + Production so /api/* proxy routes reach the API.
# Do not set this to the Next dev URL (:3000) or the proxy will call itself.
# Production: https://api.growwiseschool.org
# Local: http://localhost:3001 (growwise_backend default PORT)
NEXT_PUBLIC_BACKEND_URL=https://api.growwiseschool.org

# Pricing config for the website UI (GET /api/pricing-config):
# Default: Next.js serves public/api/mock/en/pricing-config.json (committed file + same ladder as growwise_backend).
# Set to true only in local dev to proxy pricing from NEXT_PUBLIC_BACKEND_URL for debugging; ignored in production builds.
# PRICING_CONFIG_PROXY_BACKEND=false

# Stripe — optional in Next if the backend handles checkout:
# - With NEXT_PUBLIC_BACKEND_URL set and NO STRIPE_SECRET_KEY here, Next proxies
#   /api/payment/create-checkout-session and /api/payment/session/* to the backend (Stripe in backend/.env).
# - Set STRIPE_SECRET_KEY here only if you want Next to call Stripe directly (e.g. serverless-only deploy).
# STRIPE_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...  (optional; Elements only)
# When true, the cart page shows a button to add a $1 test line item (Stripe test mode / success URL checks). Omit or false in production.
# NEXT_PUBLIC_ENABLE_TEST_CHECKOUT=true

# S3 Image Storage Configuration
# Base URL for images stored in S3 bucket
# Format: https://your-bucket-name.s3.region.amazonaws.com
# Example: https://growwise-assets.s3.us-west-1.amazonaws.com
NEXT_PUBLIC_S3_IMAGE_BASE_URL=https://growwise-assets.s3.us-west-1.amazonaws.com

# Locale Configuration
# Comma-separated list of enabled locales (e.g., "en,es,zh" or "en")
# Available locales: en, es, zh, hi
# Default: en (if not set)
NEXT_PUBLIC_ENABLED_LOCALES=en

# Default locale (must be one of the enabled locales)
# Default: first enabled locale (if not set)
NEXT_PUBLIC_DEFAULT_LOCALE=en

# Meta (Facebook) Lead Ads webhooks — POST /api/leads/meta
# GET verification: must match the Verify Token in Meta app webhook settings
META_VERIFY_TOKEN=
# App Secret — used to verify X-Hub-Signature-256 on POST (required in production)
META_APP_SECRET=
# Page/System User token with leads_retrieval — used to GET lead field_data from Graph after webhook
META_ACCESS_TOKEN=
# Optional Graph version (default v21.0), e.g. v19.0
# META_GRAPH_API_VERSION=v21.0

# Brevo (Sendinblue)
# BREVO_API_KEY=
# BREVO_SENDER_EMAIL=   # must be a verified sender/domain in Brevo
# BREVO_SENDER_NAME=GrowWise
# BREVO_LIST_LOTTERY=   # numeric list id (summer camp guide leads + Meta leads). List id 11 is never attached in code (see BREVO_LIST_IDS_EXCLUDED_FROM_AUTOMATION in src/lib/brevo.ts).
# Summer camp guide email (/api/summer-camp-lottery): tries Brevo first; if Brevo returns an error, falls back to SMTP_* below.
# If both fail, the API returns 503 (no fake success). See server logs for [summer-camp-guide] and [brevo].
# Create Text contact attributes for Meta sync: CAMP_INTEREST, GRADE, FIRSTNAME, LASTNAME, PHONE, SOURCE, etc.
# CAMP_INTEREST/GRADE map from Meta field_data names in src/lib/brevo.ts.


