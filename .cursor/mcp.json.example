{
  "mcpServers": {
    "atlassian": {
      "command": "/Users/amit/.local/bin/uvx",
      "args": ["mcp-atlassian"],
      "env": {
        "JIRA_URL": "https://YOUR-SITE.atlassian.net",
        "JIRA_USERNAME": "your-atlassian-account-email@example.com",
        "JIRA_API_TOKEN": "create-at-https://id.atlassian.com/manage-profile/security/api-tokens"
      }
    }
  }
}
