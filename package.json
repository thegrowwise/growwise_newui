{
  "name": "newgrowwise",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "lsof -ti:3000 | xargs kill -9 2>/dev/null; next dev --webpack",
    "dev:webpack": "lsof -ti:3000 | xargs kill -9 2>/dev/null; next dev --webpack",
    "dev:turbo": "lsof -ti:3000 | xargs kill -9 2>/dev/null; next dev --turbo",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src",
    "test": "jest",
    "test:perf": "node --test performance-testing/scripts/parseLighthouseBatchOptions.test.mjs",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "test:e2e": "playwright test",
    "test:e2e:chromium": "playwright test --project=chromium",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --project=chromium --headed --workers=1",
    "lighthouse:summer": "node scripts/lighthouse-summer-camp.mjs",
    "perf:lighthouse": "node performance-testing/scripts/lighthouse-batch.mjs",
    "perf:lighthouse:smoke": "node performance-testing/scripts/lighthouse-batch.mjs --smoke",
    "perf:lighthouse:smoke:mobile": "node performance-testing/scripts/lighthouse-batch.mjs --smoke --mobile-only",
    "perf:lighthouse:smoke:desktop": "node performance-testing/scripts/lighthouse-batch.mjs --smoke --desktop-only",
    "perf:lighthouse:smoke:html": "node performance-testing/scripts/lighthouse-batch.mjs --smoke --save-html",
    "perf:ci": "node performance-testing/scripts/lighthouse-batch.mjs --smoke --runs=2",
    "perf:ci:pr": "node performance-testing/scripts/lighthouse-batch.mjs --smoke --mobile-only --runs=1",
    "perf:locust": "bash performance-testing/load/run-locust-web.sh",
    "perf:locust:headless": "bash performance-testing/load/run-locust-headless.sh"
  },
